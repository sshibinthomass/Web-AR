{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "web-ar-generate-model",
  "main": "worker/src/index.ts",
  "workers_dev": true,
  "preview_urls": true,
  "compatibility_date": "2026-06-28",
  "triggers": {
    "crons": ["*/1 * * * *"]
  },
  "vars": {
    "ADMIN_EMAIL": "sshibinthomass@gmail.com",
    "MODAL_IMAGE_TO_3D_URL": "https://sshibinthomass--trellis-2-4b-fast-trellis2fastmodel-gene-1cf4f3.modal.run",
    "MODAL_IMAGE_TO_3D_START_URL": "https://sshibinthomass--trellis-2-4b-fast-trellis2fastmodel-start-api.modal.run",
    "MODAL_IMAGE_TO_3D_RESULT_URL": "https://sshibinthomass--trellis-2-4b-fast-trellis2fastmodel-result-api.modal.run",
    "MODAL_OPENAI_TO_3D_URL": "https://sshibinthomass--openai-to-3d-fast-openaiimageto3d-generate-api.modal.run",
    "MODAL_OPENAI_TO_3D_START_URL": "https://sshibinthomass--openai-to-3d-fast-openaiimageto3d-start-api.modal.run",
    "MODAL_OPENAI_TO_3D_RESULT_URL": "https://sshibinthomass--openai-to-3d-fast-openaiimageto3d-result-api.modal.run",
    "MODAL_OBJECT_PREPROCESS_QUALITY_URL": "https://sshibinthomass--object-preprocess-quality-openai-t4-qual-caeb25.modal.run",
    // Populate after the separately authorized Modal deployment; empty keeps development safely unavailable.
    "MODAL_OBJECT_SEGMENTATION_URL": "",
    "PUBLIC_MODEL_ORIGIN": "https://web-ar-generate-model.sshibinthomass.workers.dev"
  },
  "r2_buckets": [
    {
      "binding": "MODEL_BUCKET",
      "bucket_name": "web-ar-model-assets"
    }
  ]
}
